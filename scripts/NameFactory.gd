class_name NameFactory
extends Node

# パターン①用（すべて6文字以内）
const NOUNS = [
	"デーモン", "ストーム", "スター", "ドクロ", "シャドウ", "ブレード",
	"ソウル", "カオス", "フレイム", "アビス", "アイアン", "ルーン",
	"ブラッド", "ウィンド", "サンダー", "ナイト", "ヴォイド", "アース",
	"ミスト", "シルバー", "メタル", "ダーク", "ライト", "マナ",
	"オーブ", "クロス", "ファング", "ボーン", "アッシュ", "ローズ"
]
const VERBS = [
	"殺し", "乗り", "追い", "壊し", "歩き", "作り",
	"使い", "払い", "喰らい", "運び", "狩り", "殺し",
	"守り", "導き", "刈り", "起こし", "撃ち", "追い",
	"砕き", "踊り", "刺し", "斬り", "射抜き", "奪い",
	"封じ", "沈め", "呼び", "刻み", "放ち", "騙し"
]

# パターン②・③用（すべて6文字以内）
const TITLES_PREFIX = [
	"英雄", "破壊王", "竜人", "騎士", "賢者", "守護者",
	"聖女", "覇王", "亡霊", "魔導士", "処刑人", "放浪者",
	"神官", "狂戦士", "暗殺者", "預言者", "重騎士", "辺境伯",
	"超越者", "道化師", "狩人", "法王", "軍師", "占術師",
	"拳聖", "剣鬼", "剣聖", "鍛冶師", "彫刻家", "薬師"
]
const PROPER_NAMES = [
	"アーサー", "ラグナ", "ゼノン", "カイン", "シオン", "ギル",
	"リリス", "ソロモン", "イリス", "レオン", "ガウェイン", "ジーク",
	"ベオ", "バルバ", "ニクス", "ルナ", "ステラ", "ノア",
	"イヴ", "カイト", "ロキ", "オーディン", "フレア", "エルザ",
	"ルーク", "ユーリ", "クロウ", "ハク", "リン", "ガイ"
]
const TITLES_SUFFIX = [
	"博士", "将軍", "兵長", "王", "卿", "導師",
	"総督", "大公", "隠者", "監獄長", "司教", "教皇",
	"隊長", "殿下", "執事", "執行官", "語り部", "管理人",
	"審判官", "観測者", "の右腕", "の左腕", "一世", "二世",
	"三世", "老師", "大師", "公爵", "伯爵", "男爵"
]

# パターン④用（すべて6文字以内）
const ADJECTIVES = [
	"鋼の", "空駆ける", "白い手の", "虚無の", "黄金の", "静かなる",
	"飢えた", "不滅の", "孤独な", "雷鳴の", "暁の", "昏き",
	"星砕く", "名もなき", "燃える", "深淵の", "残酷な", "不屈の",
	"呪いの", "蒼き", "紅蓮の", "漆黒の", "純白の", "輝く",
	"震える", "歪んだ", "清き", "古の", "若き", "最後の"
]

## ランダムに名前を生成して返します
static func generate_name() -> String:
	var pattern_index = randi() % 4
	var result = ""

	match pattern_index:
		0: # パターン①：名詞 ＋ 動詞
			result = _get_rand(NOUNS) + _get_rand(VERBS)
		
		1: # パターン②：冠詞（称号） ＋ 固有名詞
			result = _get_rand(TITLES_PREFIX) + _get_rand(PROPER_NAMES)
			
		2: # パターン③：固有名詞 ＋ 称号
			result = _get_rand(PROPER_NAMES) + _get_rand(TITLES_SUFFIX)
			
		3: # パターン④：形容詞 ＋ 名詞/固有名詞
			var target = _get_rand(NOUNS) if randi() % 2 == 0 else _get_rand(PROPER_NAMES)
			result = _get_rand(ADJECTIVES) + target

	return result

## 配列からランダムに1つ要素を取得するヘルパー関数
static func _get_rand(list: Array) -> String:
	if list.is_empty():
		return ""
	return list[randi() % list.size()]
